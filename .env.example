# ═══════════════════════════════════════════════════════
#  Hackathon CRM — Plantilla de variables de entorno
#  Copia este fichero a .env y rellena los valores reales
# ═══════════════════════════════════════════════════════

# ─── Base de datos ──────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=HackathonDB
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ─── Aplicación ─────────────────────────────────────────
APP_NAME=Hackathon CRM
APP_VERSION=1.0.0
APP_ENV=production
BASE_URL=http://localhost/hackathon-crm

# ─── Paginación ─────────────────────────────────────────
RECORDS_PER_PAGE=15

# ─── Seguridad de sesión ─────────────────────────────────
APP_SECRET=genera_un_valor_aleatorio_con_openssl_rand_hex_32
SESSION_LIFETIME=7200
